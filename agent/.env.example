# Onyx Agent - Configuração
# Copie este arquivo para .env e preencha os valores

# URL do servidor Onyx Monitor
SERVER_URL=https://onyx-monitor-api.onrender.com

# API Key do agent (obtida no registro)
AGENT_API_KEY=

# Nome do agent
AGENT_NAME=Onyx Agent

# Company ID
COMPANY_ID=default

# Localização
LOCATION=

# Intervalo de coleta: 5m, 15m, 30m, 1h
COLLECT_INTERVAL=15m

# Porta da interface web local
UI_PORT=8080

# Comunidade SNMP padrão
SNMP_COMMUNITY=public

# Timeout SNMP em milissegundos
SNMP_TIMEOUT=5000

# Log level: info, warn, error
LOG_LEVEL=info
