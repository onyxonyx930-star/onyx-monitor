rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Regra padrão: negar tudo
    match /{document=**} {
      allow read, write: if false;
    }

    // Usuários - apenas admin pode gerenciar
    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }

    // Equipamentos - autenticados podem ler, admin pode escrever
    match /equipamentos/{equipId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }

    // Leituras - autenticados podem ler
    match /leituras/{leituraId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Suprimentos - autenticados podem ler
    match /suprimentos/{supId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Alertas - autenticados podem ler e resolver
    match /alertas/{alertaId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['resolvido', 'resolvidoEm', 'resolvidoPor']);
      allow write: if false;
    }

    // Agents - admin pode gerenciar
    match /agents/{agentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }

    // Agent Logs - apenas leitura autenticada
    match /agentLogs/{logId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Auditoria - autenticados podem ler
    match /auditoriaImpressoes/{auditId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Config Auditoria - admin pode gerenciar
    match /auditoriaConfig/{configId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }

    // Config Coleta - admin pode gerenciar
    match /configColeta/{configId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
