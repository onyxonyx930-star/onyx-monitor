{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npx vite build",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 30
    },
    "api/cron/collect.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/collect",
      "schedule": "0 8 * * *"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
